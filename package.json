{
  "name": "@shaztech/video-stitcher",
  "version": "1.0.0",
  "description": "CLI tool for stitching videos and images together using FFmpeg",
  "type": "module",
  "main": "cli.js",
  "files": [
    "cli.js",
    "bin.js"
  ],
  "bin": {
    "video-stitcher": "./bin.js"
  },
  "scripts": {
    "test": "npm run lint && npm run test:coverage",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "video",
    "stitch",
    "ffmpeg",
    "cli"
  ],
  "author": "Shazron Abdullah",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/shazron/video-stitcher"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^8.0.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^16.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
